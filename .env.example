# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development            # production | staging | development | test
LOG_LEVEL=info                 # debug | info | warn | error
SERVICE_NAME=lignin-gateway

# ── HTTP Server ───────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=120s
SERVER_SHUTDOWN_TIMEOUT=15s
SERVER_RATE_LIMIT=100          # requests/sec per IP
SERVER_RATE_BURST=20

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_DSN=postgres://lignin:lignin@localhost:5432/lignin?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=1m
DB_MIGRATIONS_DIR=migrations

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_TTL=15m

# ── M-Pesa / Daraja OAuth2 ───────────────────────────────────────────────────
MPESA_CONSUMER_KEY=<your-consumer-key>
MPESA_CONSUMER_SECRET=<your-consumer-secret>
MPESA_TOKEN_URL=https://sandbox.safaricom.co.ke/oauth/v1/generate?grant_type=client_credentials
AUTH_TOKEN_BUFFER=60s

# ── JWT (internal sessions) ───────────────────────────────────────────────────
JWT_SECRET=<min-32-byte-random-secret>
JWT_EXPIRY=24h

# ── Callback signature ────────────────────────────────────────────────────────
CALLBACK_SIG_HEADER=X-Mpesa-Signature
CALLBACK_SIG_SECRET=<shared-hmac-secret-from-safaricom>
CALLBACK_DEDUP_TTL=24h
CALLBACK_MAX_BODY_BYTES=1048576

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
